# ============================================
# 経理自動化システム (BESO) 環境変数テンプレート
# .env にコピーして値を設定してください
# ============================================

# --- 必須 (サーバー起動に必要) ---
GEMINI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase ---
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- サーバー設定 ---
PORT=3001
NODE_ENV=development

# --- フロントエンド ---
VITE_API_URL=http://localhost:3001
VITE_APP_URL=http://localhost:5173

# --- CORS ---
# カンマ区切りで複数指定可
ALLOWED_ORIGINS=http://localhost:5173

# --- Gemini モデル (任意) ---
# GEMINI_MODEL_OCR=gemini-3-flash-preview
# GEMINI_MODEL_JOURNAL=gemini-3.1-pro-preview

# --- freee連携 (任意) ---
# FREEE_CLIENT_ID=
# FREEE_CLIENT_SECRET=
# FREEE_REDIRECT_URI=http://localhost:5173/settings
