{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist/server",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/core/*": ["./src/core/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/adapters/*": ["./src/adapters/*"],
      "@/api/*": ["./src/api/*"],
      "@/web/*": ["./src/web/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/types": ["./src/shared/types/index.ts"]
    },
    "skipLibCheck": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "multer"]
  },
  "include": ["src/server/**/*", "src/shared/**/*", "src/core/**/*", "src/modules/**/*", "src/adapters/gemini/**/*", "src/adapters/freee/**/*", "src/adapters/supabase/supabase-admin.client.ts", "src/api/**/*"],
  "exclude": ["src/adapters/supabase/supabase.client.ts", "src/adapters/supabase/supabase.debug.ts", "src/**/__tests__/**/*", "src/**/*.test.ts", "src/**/*.spec.ts"]
}